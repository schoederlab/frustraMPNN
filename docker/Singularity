# FrustraMPNN Singularity Definition
#
# This definition creates a Singularity container with FrustraMPNN and all dependencies
# for running frustration predictions on HPC systems.
#
# Build from Docker: singularity build frustraMPNN.sif docker-daemon:frustrampnn:v2
# Or build directly:  singularity build frustraMPNN.sif Singularity
#
# Run: singularity exec --nv frustraMPNN.sif frustrampnn predict --help

Bootstrap: docker
From: nvidia/cuda:12.1.1-devel-ubuntu22.04

%environment
    export MAMBA_ROOT_PREFIX=/opt/conda
    export PATH=$MAMBA_ROOT_PREFIX/bin:$PATH
    export PYTHONUNBUFFERED=1

%post
    # Avoid interactive prompts
    export DEBIAN_FRONTEND=noninteractive
    export PYTHONUNBUFFERED=1

    # Install system dependencies
    apt-get update && apt-get install -y \
        curl wget git bzip2 ca-certificates libglib2.0-0 libxext6 \
        libsm6 libxrender1 libssl-dev libffi-dev vim unzip \
        && rm -rf /var/lib/apt/lists/*

    # Install Mambaforge
    export MAMBA_ROOT_PREFIX=/opt/conda
    export PATH=$MAMBA_ROOT_PREFIX/bin:$PATH
    curl -L -o mambaforge.sh https://github.com/conda-forge/miniforge/releases/download/22.9.0-1/Mambaforge-Linux-x86_64.sh
    chmod +x mambaforge.sh
    bash mambaforge.sh -b -p $MAMBA_ROOT_PREFIX
    rm mambaforge.sh

    # Create directories
    mkdir -p /app /app/results

    # Install Python and PyTorch with CUDA support
    mamba install -y -n base python=3.10 \
        numpy=1.26 pytorch=2.1.2 torchvision torchaudio pytorch-cuda=12.1 -c pytorch -c nvidia
    mamba install -y -c conda-forge -c defaults \
        biopython=1.85 pandas scipy scikit-learn tqdm matplotlib seaborn \
        pytorch-lightning omegaconf wandb plotly kaleido click
    mamba clean -a -y

    # Install ESM
    pip install fair-esm==2.0.0 absl-py grpcio markdown tensorboard werkzeug

    # Install PyRosetta (optional, for validation)
    pip install pyrosetta-installer
    python -c 'import pyrosetta_installer; pyrosetta_installer.install_pyrosetta()'
    rm -rf ~/.cache/pip

    # Install frustrapy (for validation)
    git clone https://github.com/Bloeci/frustrapy.git /app/frustrapy
    cd /app/frustrapy
    pip install -r requirements.txt
    pip install -e .

    # Install frustrampnn package from copied source
    cd /app/frustrampnn-src
    pip install -e ".[all]"
    rm -rf ~/.cache/pip

    # Create entrypoint script
    cat > /app/entrypoint.sh << 'EOF'
#!/bin/bash
source /opt/conda/etc/profile.d/conda.sh
conda activate base
export PYTHONUNBUFFERED=1

# All commands go through the frustrampnn CLI
case "$1" in
    # Direct CLI commands
    predict|train|evaluate|info|batch)
        frustrampnn "$@"
        ;;
    # Python passthrough for custom scripts
    python)
        shift
        python -Wignore "$@"
        ;;
    # Help
    --help|-h|help)
        frustrampnn --help
        ;;
    # Default: pass through to frustrampnn CLI
    *)
        frustrampnn "$@"
        ;;
esac
EOF
    chmod +x /app/entrypoint.sh

%files
    . /app/frustrampnn-src
    scripts/analysis /app/scripts/analysis

%runscript
    exec /app/entrypoint.sh "$@"

%labels
    Author FrustraMPNN Team
    Version 2.0
    Description FrustraMPNN - Ultra-fast frustration prediction

%help
    FrustraMPNN Container
    
    This container provides FrustraMPNN for ultra-fast prediction of
    single-residue local energetic frustration in proteins.
    
    Usage:
        # Show help
        singularity run frustraMPNN.sif --help
        
        # Predict frustration
        singularity exec --nv frustraMPNN.sif frustrampnn predict \
            --pdb protein.pdb --checkpoint model.ckpt
        
        # Batch prediction
        singularity exec --nv frustraMPNN.sif frustrampnn batch \
            *.pdb --checkpoint model.ckpt
        
        # Show package info
        singularity exec frustraMPNN.sif frustrampnn info
    
    For more information, visit: https://github.com/schoederlab/frustraMPNN
