Bootstrap: docker
From: nvidia/cuda:12.1.1-devel-ubuntu22.04

%environment
    export MAMBA_ROOT_PREFIX=/opt/conda
    export PATH=$MAMBA_ROOT_PREFIX/bin:$PATH
    export PYTHONUNBUFFERED=1

%post
    # Avoid interactive prompts
    export DEBIAN_FRONTEND=noninteractive
    export PYTHONUNBUFFERED=1

    # Install dependencies
    apt-get update && apt-get install -y \
        curl wget git bzip2 ca-certificates libglib2.0-0 libxext6 \
        libsm6 libxrender1 libssl-dev libffi-dev vim \
        && rm -rf /var/lib/apt/lists/*

    # Install Mambaforge
    export MAMBA_ROOT_PREFIX=/opt/conda
    export PATH=$MAMBA_ROOT_PREFIX/bin:$PATH
    curl -L -o mambaforge.sh https://github.com/conda-forge/miniforge/releases/download/22.9.0-1/Mambaforge-Linux-x86_64.sh
    chmod +x mambaforge.sh
    bash mambaforge.sh -b -p $MAMBA_ROOT_PREFIX
    rm mambaforge.sh

    # Create directories
    mkdir -p /app
    mkdir -p /app/results

    # Install packages
    mamba install -y -n base python=3.10 \
        numpy=1.26 pytorch=2.1.2 torchvision torchaudio pytorch-cuda=12.1 -c pytorch -c nvidia
    pip install fair-esm==2.0.0 absl-py grpcio markdown tensorboard werkzeug
    mamba install -y -c conda-forge -c defaults \
        biopython=1.85 pandas scipy scikit-learn tqdm matplotlib seaborn \
        pytorch-lightning omegaconf wandb
    mamba clean -a -y

    # Install PyRosetta
    pip install pyrosetta-installer
    python -c 'import pyrosetta_installer; pyrosetta_installer.install_pyrosetta()'
    rm -rf ~/.cache/pip
    
    # Install frustrapy dependencies
    git clone https://github.com/Bloeci/frustrapy.git /app/frustrapy
    cd /app/frustrapy
    pip install -r requirements.txt
    pip install -e .

    # Create entrypoint script
    cat > /app/entrypoint.sh << 'EOF'
#!/bin/bash
source /opt/conda/etc/profile.d/conda.sh
conda activate base
export PYTHONUNBUFFERED=1
case "$1" in
  inference)
    shift
    python -Wignore /app/inference/custom_inference_refac.py "$@"
    ;;
  singleresidue)
    shift
    python -Wignore /app/scripts/frustration_singleresidue.py "$@"
    ;;
  python)
    shift
    python -Wignore "$@"
    ;;
  *)
    echo "Usage: $0 {inference|singleresidue|python} [args...]"
    exit 1
    ;;
esac
EOF
    chmod +x /app/entrypoint.sh

%files
    inference /app/inference
    scripts /app/scripts

%runscript
    exec /app/entrypoint.sh "$@"